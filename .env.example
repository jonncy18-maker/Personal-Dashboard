# ─── SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix — never exposed to the browser) ───
# These live only in server-side route handlers under app/api/*.
# NEVER prefix a secret with NEXT_PUBLIC_ — that inlines it into the client bundle.
#
# Set EVERY one of these for BOTH Production AND Preview in Vercel explicitly.
# A var present only in Production makes Preview deploys fail in ways that look
# like a runtime bug, not a config bug (see STACK_BLUEPRINT.md Part 2).

# Neon connection string — full DB access. Server only.
# (Vercel+Neon integration auto-creates DATABASE_URL; NEON_DATABASE_URL is a
# manual override if you provision the DB outside the integration.)
DATABASE_URL=

# Anthropic key — claude-haiku-4-5. Narrow use only: Email Tier 2 semantic
# residual + Travel itinerary parse. Server only.
ANTHROPIC_API_KEY=

# Vercel API token — READ-ONLY project/deployment scope for the AI Projects
# domain's live status cards. Scope it read-only in Vercel's token UI if
# available; a leaked deploy-capable token is a materially worse failure. Server only.
VERCEL_API_TOKEN=

# Google OAuth — one client, read-only scopes for BOTH Calendar (next Spanish
# tutor call) and Gmail (Email domain + Travel itinerary search). Server only.
# Gmail scope is read-only by design — no code path may call a write/modify/delete endpoint.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── CLIENT-SIDE (public-prefixed — safe to expose) ───

# Same-origin base URL of the app.
NEXT_PUBLIC_APP_URL=
